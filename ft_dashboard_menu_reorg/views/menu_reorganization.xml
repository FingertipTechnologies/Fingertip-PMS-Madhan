<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================= -->
        <!-- Project Dashboard -> moved inside PMS (Project) -->
        <!-- ============================================= -->
        <record id="ft_project_dashboard.menu_ft_project_dashboard_root" model="ir.ui.menu">
            <field name="name">Dashboard</field>
            <field name="parent_id" ref="project.menu_main_pm"/>
            <!-- Negative so "Dashboard" is first even in apps whose first
                 menu already sits at sequence 0 (e.g. CRM > Customers).
                 Odoo orders menus by "sequence, id". -->
            <field name="sequence">-1</field>
        </record>

        <!-- ============================================= -->
        <!-- Sales Dashboard -> moved inside CRM -->
