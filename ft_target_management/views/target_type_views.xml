<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ft_target_type_list" model="ir.ui.view">
        <field name="name">ft.target.type.list</field>
        <field name="model">ft.target.type</field>
        <field name="arch" type="xml">
            <list string="Target Types" editable="bottom">
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_role_id"/>
            </list>
        </field>
    </record>

    <record id="view_ft_target_type_form" model="ir.ui.view">
        <field name="name">ft.target.type.form</field>
        <field name="model">ft.target.type</field>
        <field name="arch" type="xml">
            <form string="Target Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="department_id"/>
                        <field name="job_role_id"/>
                        <field name="active" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ft_target_type" model="ir.actions.act_window">
        <field name="name">Target Types</field>
        <field name="res_model">ft.target.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
