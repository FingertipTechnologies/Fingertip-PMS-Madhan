<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ft_target_period_list" model="ir.ui.view">
        <field name="name">ft.target.period.list</field>
        <field name="model">ft.target.period</field>
        <field name="arch" type="xml">
            <list string="Target Periods" editable="bottom">
                <field name="name" width="33%"/>
                <field name="start_date" width="33%"/>
                <field name="end_date" width="34%"/>
            </list>
        </field>
    </record>

    <record id="view_ft_target_period_form" model="ir.ui.view">
        <field name="name">ft.target.period.form</field>
        <field name="model">ft.target.period</field>
        <field name="arch" type="xml">
            <form string="Target Period">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="active" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ft_target_period" model="ir.actions.act_window">
        <field name="name">Target Periods</field>
        <field name="res_model">ft.target.period</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
