<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pms_suggestion_category_list" model="ir.ui.view">
        <field name="name">pms.suggestion.category.list</field>
        <field name="model">pms.suggestion.category</field>
        <field name="arch" type="xml">
            <list string="Modules / Areas" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_pms_suggestion_category" model="ir.actions.act_window">
        <field name="name">Suggestion Modules / Areas</field>
        <field name="res_model">pms.suggestion.category</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Seed a few common areas so the dropdown isn't empty on install -->
    <record id="category_general" model="pms.suggestion.category">
        <field name="name">General PMS</field>
        <field name="sequence">10</field>
    </record>
    <record id="category_training" model="pms.suggestion.category">
        <field name="name">Training</field>
        <field name="sequence">20</field>
    </record>
    <record id="category_helpdesk" model="pms.suggestion.category">
        <field name="name">Help Desk</field>
        <field name="sequence">30</field>
    </record>
    <record id="category_sfa" model="pms.suggestion.category">
        <field name="name">SFA / CRM</field>
        <field name="sequence">40</field>
    </record>
    <record id="category_other" model="pms.suggestion.category">
        <field name="name">Other</field>
        <field name="sequence">100</field>
    </record>

</odoo>
