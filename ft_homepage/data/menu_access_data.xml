<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data noupdate="0">

   

    <!-- General PMS — All users -->
    <record id="general.menu_general_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [])]"/>
    </record>

    <!-- Project app — open to all users, so that the
         "Quotes / Announcements" menu placed under it is visible to
         everyone (the standard Project root menu is otherwise limited
         to Project User / Project Manager groups). -->
    <record id="project.menu_main_pm" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [])]"/>
    </record>

    <!-- Training — All users (root menu already has no group restriction,
         so every internal user, including Trainees, already sees it; kept
         explicit here for clarity/auditability). -->
    <record id="ft_training.menu_training_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [])]"/>
    </record>

    <!-- Old Helpdesk app (round icon, helpdesk_mgmt) — removed from the
         Homepage for ALL accounts. -->
    <record id="helpdesk_mgmt.helpdesk_ticket_main_menu" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    <!-- FT Helpdesk — helpdesk roles + PMs. NOT for sales/marketing
         (they only see it if they're also given a helpdesk role).
         active=True re-shows it in case a previous run of
         ft_app_menu_cleanup (which used to list "Helpdesk") had hidden it. -->
    <record id="ft_helpdesk_core.menu_ft_helpdesk_root" model="ir.ui.menu">
        <field name="active" eval="True"/>
        <field name="groups_id" eval="[
            (6, 0, [
                ref('ft_helpdesk_core.group_ft_helpdesk_agent'),
                ref('project.group_project_manager'),
            ])
        ]"/>
    </record>

    <!-- Employees — common / all. active=True re-shows it in case a previous
         run of ft_app_menu_cleanup (which used to list "Employees") hid it. -->
    <record id="hr.menu_hr_root" model="ir.ui.menu">
        <field name="active" eval="True"/>
        <field name="groups_id" eval="[(6, 0, [])]"/>
    </record>

    <!-- CRM — Sales team only -->
    <record id="crm.crm_menu_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('sales_team.group_sale_salesman')])]"/>
    </record>

    <!-- Sales and Email Marketing are fully removed for everyone —
         see the deactivation block at the end of this file. -->

    <!-- Scorecard — PMs + Project Coordinators only -->
    <record id="Project_Scorecards.menu_project_scorecard_root" model="ir.ui.menu">
        <field name="groups_id" eval="[
            (6, 0, [
                ref('project.group_project_manager'),
                ref('ft_homepage.group_project_coordinator'),
            ])
        ]"/>
    </record>

    <!-- Dashboard — Admin only.
         VERIFY: confirm the spreadsheet_dashboard root menu external id
         (module not present in this codebase / installed separately). -->
    <record id="spreadsheet_dashboard.spreadsheet_dashboard_menu_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- AI Insights — Admin only -->
    <record id="ft_ai_sales_insights.menu_ai_insights_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Target — Admin only -->
    <record id="ft_target_management.menu_ft_target_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Invoicing — Admin + Sales only -->
    <record id="account.menu_finance" model="ir.ui.menu">
        <field name="groups_id" eval="[
            (6, 0, [
                ref('base.group_system'),
                ref('sales_team.group_sale_salesman'),
            ])
        ]"/>
    </record>

    <!-- Invoicing: hide the standard Odoo "Dashboard" (Accounting/Invoicing
         dashboard kanban). The department Finance Dashboard is added inside
         Invoicing instead by ft_dashboard_menu_reorg. -->
    <record id="account.menu_board_journal_1" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- QA Techstar Test App — hide for everyone (already covered inside
         PMS/Project, kept installed but removed from the Homepage/menu
         entirely). -->
    <record id="qa_testapp.qa_testapp_menu_root" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Link Tracker — Sales + Admin. The stock root menu is hidden
         behind the developer-mode group (base.group_no_one), so we
         replace its groups outright. -->
    <record id="utm.menu_link_tracker_root" model="ir.ui.menu">
        <field name="groups_id" eval="[
            (6, 0, [
                ref('base.group_system'),
                ref('sales_team.group_sale_salesman'),
            ])
        ]"/>
    </record>
    <record id="link_tracker.link_tracker_menu_main" model="ir.ui.menu">
        <field name="groups_id" eval="[
            (6, 0, [
                ref('base.group_system'),
                ref('sales_team.group_sale_salesman'),
            ])
        ]"/>
    </record>

    <!-- Website — removed from the Homepage for ALL users -->
    <record id="website.menu_website_configuration" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- ================================================================
         Apps removed from the Homepage for EVERYONE (admins included).
         Deactivating the root menu is the only way to hide an app from
         admins too — group restrictions don't apply to them since the
         admin belongs to / implies most groups.
         ================================================================ -->

    <!-- Discuss -->
    <record id="mail.menu_root_discuss" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Calendar -->
    <record id="calendar.mail_menu_calendar" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Sales -->
    <record id="sale.sale_menu_root" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- eLearning -->
    <record id="website_slides.website_slides_menu_root" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Email Marketing -->
    <record id="mass_mailing.mass_mailing_menu_root" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

</data>
</odoo>
