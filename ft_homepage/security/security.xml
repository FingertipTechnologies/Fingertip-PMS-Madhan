<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_ft_homepage" model="ir.module.category">
            <field name="name">Homepage Access</field>
            <field name="sequence">99</field>
        </record>

        <!-- The access matrix requires a "Project Coordinator" role (for
             Scorecard access) that doesn't exist yet anywhere in the
             codebase. Modelled on project.group_project_user so it can be
             assigned from Settings > Users > Access Rights. -->
        <record id="group_project_coordinator" model="res.groups">
            <field name="name">Project Coordinator</field>
            <field name="category_id" ref="module_category_ft_homepage"/>
            <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
            <field name="comment">Project Coordinators: used to grant access to
                the Scorecard app alongside Project Managers.</field>
        </record>

    </data>
</odoo>
