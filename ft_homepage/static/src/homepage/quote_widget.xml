<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <!-- Insert the Quote/Announcement widget below the app icons grid on
         the Homepage (web_responsive's Apps Menu). -->
    <t t-inherit="web_responsive.AppsMenu" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-app-menu-list')]" position="after">
            <FtQuoteWidget/>
        </xpath>
    </t>

    <t t-name="ft_homepage.QuoteWidget">
        <div class="ft_quote_widget" t-if="state.loaded and state.content">

            <!-- TEXT: decorative quotation marks + marquee scroll effect -->
            <div t-if="state.content.content_type == 'text'" class="ft_quote_widget__marquee_track">
                <div class="ft_quote_widget__inner ft_quote_widget__text">
                    <span class="ft_quote_widget__mark ft_quote_widget__mark--open">&#8220;</span>
                    <span class="ft_quote_widget__quote_text" t-esc="state.content.text_content"/>
                    <span class="ft_quote_widget__mark ft_quote_widget__mark--close">&#8221;</span>
                    <span t-if="state.content.contributor" class="ft_quote_widget__contributor">
                        — <t t-esc="state.content.contributor"/>
                    </span>
                </div>
            </div>

            <!-- IMAGE (static, not scrolled) -->
            <div t-if="state.content.content_type == 'image'" class="ft_quote_widget__media">
                <img t-att-src="state.content.image_url" class="ft_quote_widget__image" alt="Announcement"/>
                <span t-if="state.content.contributor" class="ft_quote_widget__contributor">
                    — <t t-esc="state.content.contributor"/>
                </span>
            </div>

            <!-- VIDEO (static, not scrolled) -->
            <div t-if="state.content.content_type == 'video'" class="ft_quote_widget__media">
                <iframe t-if="isYoutube"
                        class="ft_quote_widget__video"
                        t-att-src="youtubeEmbedUrl"
                        title="Announcement video"
                        allow="autoplay; encrypted-media; fullscreen"
                        allowfullscreen="allowfullscreen"/>
                <video t-else="" class="ft_quote_widget__video" controls="controls"
                       autoplay="autoplay" muted="muted" playsinline="playsinline">
                    <source t-att-src="state.content.video_url"/>
                </video>
                <span t-if="state.content.contributor" class="ft_quote_widget__contributor">
                    — <t t-esc="state.content.contributor"/>
                </span>
            </div>

        </div>
    </t>

</templates>
