<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <!-- Insert the Quote/Announcement widget below the app icons grid on
         the Homepage (web_responsive's Apps Menu). -->
    <t t-inherit="web_responsive.AppsMenu" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-app-menu-list')]" position="after">
            <FtQuoteWidget/>
        </xpath>
    </t>

    <t t-name="ft_homepage.QuoteWidget">
        <div class="ft_quote_widget" t-if="state.loaded and state.items.length">
            <t t-foreach="state.items" t-as="item" t-key="item.id">

                <!-- TEXT: decorative quotation marks + marquee scroll effect -->
                <div t-if="item.content_type == 'text'" class="ft_quote_widget__marquee_track">
                    <div class="ft_quote_widget__inner ft_quote_widget__text">
                        <span class="ft_quote_widget__mark ft_quote_widget__mark--open">&#8220;</span>
                        <span class="ft_quote_widget__quote_text" t-esc="item.text_content"/>
                        <span class="ft_quote_widget__mark ft_quote_widget__mark--close">&#8221;</span>
                        <span t-if="item.contributor" class="ft_quote_widget__contributor">
                            — <t t-esc="item.contributor"/>
                        </span>
                    </div>
                </div>

                <!-- IMAGE (static, not scrolled) -->
                <div t-if="item.content_type == 'image'" class="ft_quote_widget__media">
                    <img t-att-src="item.image_url" class="ft_quote_widget__image" alt="Announcement"/>
                    <span t-if="item.contributor" class="ft_quote_widget__contributor">
                        — <t t-esc="item.contributor"/>
                    </span>
                </div>

                <!-- VIDEO: uploaded file first, else YouTube embed, else
                     a direct URL; all autoplay muted. -->
                <div t-if="item.content_type == 'video'" class="ft_quote_widget__media">
                    <video t-if="item.video_src" class="ft_quote_widget__video" controls="controls"
                           autoplay="autoplay" muted="muted" playsinline="playsinline" loop="loop">
                        <source t-att-src="item.video_src"/>
                    </video>
                    <iframe t-elif="isYoutube(item)"
                            class="ft_quote_widget__video"
                            t-att-src="youtubeEmbedUrl(item)"
                            title="Announcement video"
                            allow="autoplay; encrypted-media; fullscreen"
                            allowfullscreen="allowfullscreen"/>
                    <video t-else="" class="ft_quote_widget__video" controls="controls"
                           autoplay="autoplay" muted="muted" playsinline="playsinline">
                        <source t-att-src="item.video_url"/>
                    </video>
                    <span t-if="item.contributor" class="ft_quote_widget__contributor">
                        — <t t-esc="item.contributor"/>
                    </span>
                </div>

            </t>
        </div>
    </t>

</templates>
