<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ============================ KPI CARD ============================ -->
    <t t-name="ft_project_dashboard.KpiCard">
        <div class="ftpd_kpi" t-att-class="{ 'ftpd_kpi--clickable': clickable }"
             t-on-click="onCardClick" t-att-title="props.tooltip">
            <div class="ftpd_kpi_icon" t-attf-style="background: {{ props.color || '#4F46E5' }}1A; color: {{ props.color || '#4F46E5' }};">
                <i class="fa" t-att-class="props.icon || 'fa-chart-bar'"/>
            </div>
            <div class="ftpd_kpi_body">
                <div class="ftpd_kpi_value">
                    <t t-esc="displayValue"/><span class="ftpd_kpi_suffix" t-if="props.suffix"><t t-esc="props.suffix"/></span>
                </div>
                <div class="ftpd_kpi_title"><t t-esc="props.title"/></div>
            </div>
        </div>
    </t>

    <!-- =========================== CHART CARD =========================== -->
    <t t-name="ft_project_dashboard.ChartCard">
        <div class="ftpd_chart_card" t-att-class="{ 'ftpd_chart_card--full': props.fullWidth }">
            <div class="ftpd_chart_head ftpd_table_head">
                <div>
                    <h3 class="ftpd_chart_title"><t t-esc="props.title"/></h3>
                    <small class="ftpd_chart_note" t-if="props.note"><t t-esc="props.note"/></small>
                </div>
                <div class="ftpd_table_tools" t-if="props.slots and props.slots.tools">
                    <t t-slot="tools"/>
                </div>
            </div>
            <div class="ftpd_chart_legend" t-if="props.scrollMinWidth">
                <t t-foreach="props.data.datasets or []" t-as="ds" t-key="ds_index">
                    <span class="ftpd_legend_item">
                        <span class="ftpd_legend_dot" t-attf-style="background: {{ ds.backgroundColor }};"/>
                        <t t-esc="ds.label"/>
                    </span>
                </t>
            </div>
            <div class="ftpd_chart_canvas_wrap" t-att-class="{ 'ftpd_chart_scroll': props.scrollMinWidth }">
                <canvas t-if="props.scrollMinWidth" t-ref="axis" class="ftpd_chart_axis"/>
                <div class="ftpd_chart_scrollarea">
                    <div class="ftpd_chart_canvas_inner"
                         t-attf-style="{{ props.scrollMinWidth ? 'min-width:' + props.scrollMinWidth + 'px;' : '' }}">
                        <canvas t-ref="canvas"/>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <!-- =========================== DATA TABLE =========================== -->
    <t t-name="ft_project_dashboard.DataTable">
        <div class="ftpd_chart_card ftpd_chart_card--full">
            <div class="ftpd_chart_head ftpd_table_head">
                <h3 class="ftpd_chart_title"><t t-esc="props.title"/></h3>
                <div class="ftpd_table_tools" t-if="props.slots and props.slots.tools">
                    <t t-slot="tools"/>
                </div>
            </div>
            <div class="ftpd_table_wrap ftpd_table_scroll">
                <table class="ftpd_table">
                    <thead>
                        <tr>
                            <t t-foreach="props.columns" t-as="col" t-key="col.key">
                                <th t-att-class="headClass(col)" t-on-click="() => this.onSort(col.key)">
                                    <t t-esc="col.label"/>
                                    <i class="fa ftpd_sort_ico" t-att-class="sortIcon(col)"/>
                                </th>
                            </t>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="pagedRows" t-as="row" t-key="row_index">
                            <tr t-att-class="{ 'ftpd_group_child': !row.__first, 'ftpd_group_mid': row.__mid }">
                                <t t-foreach="props.columns" t-as="col" t-key="col.key">
                                    <td t-att-class="cellClass(col)"><t t-esc="cellValue(row, col)"/></td>
                                </t>
                            </tr>
                        </t>
                        <tr t-if="!pagedRows.length">
                            <td t-att-colspan="props.columns.length" class="ftpd_table_empty">
                                <t t-esc="props.emptyText || 'No records found.'"/>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="ftpd_table_foot ftpd_pager" t-if="props.rows.length">
                <div class="ftpd_pager_left">
                    <span class="ftpd_table_count">
                        Showing <t t-esc="rangeStart"/>–<t t-esc="rangeEnd"/> of <t t-esc="sortedRows.length"/>
                        <t t-if="props.groupKey"> (<t t-esc="groupCount"/> <t t-esc="props.groupLabel || 'groups'"/>)</t>
                    </span>
                    <label class="ftpd_page_size">
                        Rows:
                        <select t-on-change="onPageSize">
                            <t t-foreach="pageSizes" t-as="ps" t-key="ps">
                                <option t-att-value="ps" t-att-selected="ps === state.pageSize"><t t-esc="ps"/></option>
                            </t>
                        </select>
                    </label>
                </div>
                <div class="ftpd_pager_ctrls">
                    <button class="ftpd_page_btn" t-att-disabled="currentPage === 0" t-on-click="prev">
                        <i class="fa fa-angle-left"/> Prev
                    </button>
                    <t t-foreach="pageNumbers" t-as="p" t-key="p">
                        <button class="ftpd_page_btn"
                                t-att-class="{ 'ftpd_page_btn--active': p === currentPage }"
                                t-on-click="() => this.goto(p)"><t t-esc="p + 1"/></button>
                    </t>
                    <button class="ftpd_page_btn" t-att-disabled="currentPage >= pageCount - 1" t-on-click="next">
                        Next <i class="fa fa-angle-right"/>
                    </button>
                </div>
            </div>
        </div>
    </t>

    <!-- ========================= MAIN DASHBOARD ========================= -->
    <t t-name="ft_project_dashboard.ProjectDashboard">
        <div class="ftpd_dashboard">

            <!-- Sticky header -->
            <div class="ftpd_header">
                <h1 class="ftpd_header_title">
                    <i class="fa fa-rocket me-2"/>Project Dashboard
                </h1>
                <div class="ftpd_header_tools">
                    <div class="ftpd_periods">
                        <t t-foreach="periods" t-as="p" t-key="p.id">
                            <button class="ftpd_period_btn"
                                    t-att-class="{ 'ftpd_period_btn--active': state.period === p.id }"
                                    t-on-click="() => this.onPeriodChange(p.id)">
                                <t t-esc="p.label"/>
                            </button>
                        </t>
                    </div>
                    <div class="ftpd_custom" t-if="state.period === 'custom'">
                        <input type="date" class="ftpd_date" t-att-value="state.dateFrom"
                               t-on-change="(ev) => this.onCustomDateChange('dateFrom', ev)"/>
                        <span>→</span>
                        <input type="date" class="ftpd_date" t-att-value="state.dateTo"
                               t-on-change="(ev) => this.onCustomDateChange('dateTo', ev)"/>
                        <button class="ftpd_btn ftpd_btn--primary" t-on-click="applyCustomRange">Apply</button>
                    </div>
                    <button class="ftpd_btn" t-on-click="refresh" title="Refresh">
                        <i class="fa fa-refresh"/>
                    </button>
                </div>
            </div>

            <!-- Loading overlay -->
            <div class="ftpd_loading" t-if="state.loading">
                <i class="fa fa-circle-o-notch fa-spin fa-2x"/>
            </div>

            <div t-else="" class="ftpd_content">

                <!-- KPI Row 1 -->
                <div class="ftpd_kpi_grid">
                    <KpiCard title="'Active Projects'" value="kpis.active_projects"
                             icon="'fa-folder-open'" color="'#4F46E5'"
                             onClick="() => this.openActiveProjects()"/>
                    <KpiCard title="'Hours Spent'" value="kpis.hours_spent" suffix="'h'"
                             icon="'fa-clock-o'" color="'#F59E0B'"
                             onClick="() => this.openTimesheets(false)"/>
                    <KpiCard title="'Billable Hours'" value="kpis.billable_hours" suffix="'h'"
                             icon="'fa-money'" color="'#10B981'"
                             onClick="() => this.openTimesheets(true)"/>
                    <KpiCard title="'Developers'" value="kpis.developers"
                             icon="'fa-code'" color="'#06B6D4'"/>
                    <KpiCard title="'Testers'" value="kpis.testers"
                             icon="'fa-bug'" color="'#8B5CF6'"/>
                </div>

                <!-- KPI Row 2 -->
                <div class="ftpd_kpi_grid">
                    <KpiCard title="'Project Managers'" value="kpis.project_managers"
                             icon="'fa-user-circle'" color="'#EC4899'"/>
                    <KpiCard title="'Estimated Hours'" value="kpis.hours_estimated" suffix="'h'"
                             icon="'fa-hourglass-half'" color="'#3B82F6'"/>
                    <KpiCard title="'Remaining Hours'" value="kpis.hours_remaining" suffix="'h'"
                             icon="'fa-hourglass-end'" color="'#F97316'"/>
                    <KpiCard title="'Resource Need'" value="kpis.resource_need"
                             icon="'fa-users'" color="'#EF4444'"
                             tooltip="'No capacity/planning model installed yet.'"/>
                    <KpiCard title="'Available Resources'" value="kpis.available_resources"
                             icon="'fa-user-plus'" color="'#14B8A6'"
                             tooltip="'No capacity/planning model installed yet.'"/>
                </div>

                <!-- Full-width table: Project Status -->
                <div class="ftpd_chart_row">
                    <DataTable title="'Project Status'"
                               columns="projectColumns"
                               rows="projectRows"
                               emptyText="'No projects found.'"
                               defaultSort="{ key: 'project', dir: 'asc' }">
                        <t t-set-slot="tools">
                            <div class="ftpd_search">
                                <i class="fa fa-search"/>
                                <input type="text" placeholder="Search company…"
                                       t-att-value="state.projectSearch"
                                       t-on-input="onProjectSearch"/>
                            </div>
                        </t>
                    </DataTable>
                </div>

                <!-- Full-width table: Resource Status -->
                <div class="ftpd_chart_row">
                    <DataTable title="'Resource Status'"
                               columns="resourceColumns"
                               rows="resourceRows"
                               groupKey="'employee'"
                               groupLabel="'resources'"
                               emptyText="'No resource activity found.'"
                               defaultSort="{ key: 'employee', dir: 'asc' }">
                        <t t-set-slot="tools">
                            <div class="ftpd_search">
                                <i class="fa fa-search"/>
                                <input type="text" placeholder="Search resource…"
                                       t-att-value="state.resourceSearch"
                                       t-on-input="onResourceSearch"/>
                            </div>
                            <div class="ftpd_search">
                                <i class="fa fa-search"/>
                                <input type="text" placeholder="Search project…"
                                       t-att-value="state.resourceProjectSearch"
                                       t-on-input="onResourceProjectSearch"/>
                            </div>
                        </t>
                    </DataTable>
                </div>

                <!-- Charts Row: project hours (full width) -->
                <div class="ftpd_chart_row">
                    <ChartCard title="'Project Hours Analysis'" type="'bar'"
                               data="projectHoursData" fullWidth="true"
                               scrollMinWidth="projectHoursMinWidth"
                               onSegmentClick="(i) => this.onProjectHoursSegment(i)">
                        <t t-set-slot="tools">
                            <div class="ftpd_search">
                                <i class="fa fa-search"/>
                                <input type="text" placeholder="Search project…"
                                       t-att-value="state.projectHoursSearch"
                                       t-on-input="onProjectHoursSearch"/>
                            </div>
                        </t>
                    </ChartCard>
                </div>

                <!-- Charts Row: billable + team -->
                <div class="ftpd_chart_row">
                    <ChartCard title="'Billable vs Non-Billable Hours'" type="'bar'"
                               data="charts.billable"/>
                    <ChartCard title="'Team Composition'" type="'pie'"
                               data="charts.team_composition"/>
                </div>

                <!-- Charts Row: progress trend (full width) -->
                <div class="ftpd_chart_row">
                    <ChartCard title="'Project Progress Trend'" type="'line'"
                               data="charts.progress_trend" options="trendOptions"
                               fullWidth="true"/>
                </div>

            </div>
        </div>
    </t>

</templates>
