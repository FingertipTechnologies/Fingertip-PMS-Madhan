<odoo>
    <record id="view_partner_form_inherit_custom" model="ir.ui.view">
        <field name="name">res.partner.form.custom.fields</field>
        <field name="model">res.partner</field>
        <field name="priority">1</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='category_id']" position="after">
<!--                <field name="name" string="Account Name" invisible="is_company == False"/>-->
                <field name="account_status_id" invisible="is_company == False"/>
                <field name="activity_count_custom" invisible="is_company == False"/>
                <field name="annual_revenue" invisible="1"/>
                <field name="annual_revenue_currency_id" invisible="1"/>
                <field name="annual_revenue_amount" invisible="is_company == False"/>
                <field name="annual_revenue_range" invisible="is_company == False"/>
                <field name="company_linkedin" invisible="is_company == False"/>
<!--                <field name="phone" invisible="is_company == False"/>-->
                <field name="industry_id" invisible="is_company == False"/>
                <field name="rating" invisible="is_company == False"/>
                <field name="contact_date" invisible="is_company == False"/>

                <field name="number_of_contacts"
                        invisible="is_company == False"/>

                    <field name="connected_contacts"
                        widget="many2many_tags"
                        invisible="is_company == False"/>
            </xpath>

            <!-- Dedicated rich-text Description tab, beside Internal Notes,
                 shown only for companies. -->
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page string="Description" name="company_description"
                      invisible="is_company == False">
                    <field name="description" nolabel="1"
                           placeholder="Company description..."/>
                </page>
            </xpath>

            <xpath expr="//field[@name='vat']" position="after">
                <field name="duplicate_check" invisible="is_company == False"/>
                <field name="company_eid" invisible="is_company == False"/>
                <field name="employees" invisible="is_company == False"/>
                <field name="first_activity_datetime" readonly="True"/>
                <field name="last_activity_datetime" readonly="True"/>
                <field name="pain_points" invisible="is_company == False"/>
                <field name="source_id" invisible="is_company == False"/>
                <field name="sub_vertical" invisible="is_company == False"/>
                <field name="working_date" invisible="is_company == False"/>
            </xpath>

            <xpath expr="//field[@name='website']" position="before">
                <field name="email_1" widget="email" invisible="is_company == True"/>
                <field name="email_2" widget="email" invisible="is_company == True"/>

            </xpath>

            <!-- Website is mandatory for Companies, optional for Individuals -->
            <xpath expr="//field[@name='website']" position="attributes">
                <attribute name="required">is_company == True</attribute>
            </xpath>

            <xpath expr="//field[@name='mobile']" position="after">
                <field name="mobile_1" widget="phone"/>
            </xpath>

            <xpath expr="//group[@name='misc']//field[@name='industry_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>


            <xpath expr="//field[@name='vat']" position="after">
                <field name="contact_eid" invisible="is_company == True"/>
                <field name="contact_account" invisible="is_company == True"/>
                <field name="contact_linkedin" invisible="is_company == True"/>
                <field name="company_id" invisible="is_company == True"/>
                <field name="department" invisible="is_company == True"/>
            </xpath>

        </field>
    </record>
</odoo>
