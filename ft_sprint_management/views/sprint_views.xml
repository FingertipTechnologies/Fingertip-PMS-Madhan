<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="qa_testapp_view_sprint_list" model="ir.ui.view">
        <field name="name">qa_testapp.sprint.list</field>
        <field name="model">qa_testapp.sprint</field>
        <field name="arch" type="xml">
            <list string="Sprints">
                <field name="name"/>
                <field name="project_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="task_count"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Kanban View (grouped by status) -->
    <record id="qa_testapp_view_sprint_kanban" model="ir.ui.view">
        <field name="name">qa_testapp.sprint.kanban</field>
        <field name="model">qa_testapp.sprint</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" sample="1">
                <field name="name"/>
                <field name="project_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="task_count"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div class="o_kanban_record_subtitle text-muted">
                                    <i class="fa fa-folder-open me-1" title="Project"/>
                                    <field name="project_id"/>
                                </div>
                                <div class="mt-1">
                                    <i class="fa fa-calendar me-1" title="Dates"/>
                                    <field name="start_date"/> → <field name="end_date"/>
                                </div>
                                <div class="mt-1">
                                    <span class="badge text-bg-primary">
                                        <field name="task_count"/> Tasks
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="qa_testapp_view_sprint_form" model="ir.ui.view">
        <field name="name">qa_testapp.sprint.form</field>
        <field name="model">qa_testapp.sprint</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="planned,working,testing,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tasks" type="object"
                                class="oe_stat_button" icon="fa-tasks">
                            <field name="task_count" widget="statinfo" string="Tasks"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Sprint 1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tasks">
                            <field name="task_ids" context="{'default_project_id': project_id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="stage_id"/>
                                    <field name="user_ids" widget="many2many_avatar_user"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="qa_testapp_view_sprint_search" model="ir.ui.view">
        <field name="name">qa_testapp.sprint.search</field>
        <field name="model">qa_testapp.sprint</field>
        <field name="arch" type="xml">
            <search string="Sprints">
                <field name="name"/>
                <field name="project_id"/>
                <filter name="planned" string="Planned" domain="[('state', '=', 'planned')]"/>
                <filter name="working" string="Working" domain="[('state', '=', 'working')]"/>
                <filter name="testing" string="Testing" domain="[('state', '=', 'testing')]"/>
                <filter name="completed" string="Completed" domain="[('state', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_project" string="Project" context="{'group_by': 'project_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Add Sprint field on the Task form -->
    <record id="qa_testapp_view_task_form_sprint" model="ir.ui.view">
        <field name="name">project.task.form.sprint</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <field name="user_ids" position="after">
                <field name="sprint_id"
                       options="{'no_create_edit': True}"/>
            </field>
        </field>
    </record>

    <!-- Action -->
    <record id="qa_testapp_action_sprint" model="ir.actions.act_window">
        <field name="name">Sprints</field>
        <field name="res_model">qa_testapp.sprint</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="qa_testapp_view_sprint_search"/>
    </record>

    <!-- Menu: Sprints under the Project (PMS) app -->
    <menuitem id="menu_ft_sprints"
              name="Sprints"
              parent="project.menu_main_pm"
              action="qa_testapp_action_sprint"
              sequence="30"/>
</odoo>
