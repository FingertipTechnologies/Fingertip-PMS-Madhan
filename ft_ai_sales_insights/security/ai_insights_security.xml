<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_ai_insights" model="ir.module.category">
            <field name="name">AI Sales Insights</field>
            <field name="sequence">90</field>
        </record>

        <!-- End user: can run analyses and read their own logs. -->
        <record id="group_ai_insights_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_ai_insights"/>
            <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <!-- Manager: configuration, purposes, and all logs. -->
        <record id="group_ai_insights_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_ai_insights"/>
            <field name="implied_ids" eval="[(4, ref('group_ai_insights_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <!-- Users may only read their own request logs; managers see all. -->
        <record id="rule_ai_log_own" model="ir.rule">
            <field name="name">AI Insight logs: own only</field>
            <field name="model_id" ref="model_ft_ai_insights_log"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ai_insights_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_ai_log_manager_all" model="ir.rule">
            <field name="name">AI Insight logs: managers see all</field>
            <field name="model_id" ref="model_ft_ai_insights_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ai_insights_manager'))]"/>
        </record>

    </data>
</odoo>
