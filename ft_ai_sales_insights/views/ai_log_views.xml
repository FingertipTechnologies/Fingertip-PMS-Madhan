<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ai_insights_log_list" model="ir.ui.view">
        <field name="name">ft.ai.insights.log.list</field>
        <field name="model">ft.ai.insights.log</field>
        <field name="arch" type="xml">
            <list string="AI Requests" create="false">
                <field name="create_date"/>
                <field name="user_id"/>
                <field name="purpose_id"/>
                <field name="provider"/>
                <field name="model"/>
                <field name="total_tokens" sum="Tokens"/>
                <field name="duration_ms"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'success'"
                       decoration-danger="status == 'error'"/>
            </list>
        </field>
    </record>

    <record id="view_ai_insights_log_form" model="ir.ui.view">
        <field name="name">ft.ai.insights.log.form</field>
        <field name="model">ft.ai.insights.log</field>
        <field name="arch" type="xml">
            <form string="AI Request" create="false">
                <header>
                    <button name="action_post_to_chatter" type="object"
                            string="Post to Chatter" class="btn-secondary"
                            invisible="not response"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="purpose_id"/>
                            <field name="create_date"/>
                        </group>
                        <group>
                            <field name="provider"/>
                            <field name="model"/>
                            <field name="prompt_tokens"/>
                            <field name="completion_tokens"/>
                            <field name="total_tokens"/>
                            <field name="duration_ms"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Response">
                            <field name="response"/>
                        </page>
                        <page string="Filters">
                            <field name="filters_json"/>
                        </page>
                        <page string="Payload (debug)" invisible="not payload_json">
                            <field name="payload_json"/>
                        </page>
                        <page string="Error" invisible="status != 'error'">
                            <field name="error_message"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ai_insights_log" model="ir.actions.act_window">
        <field name="name">AI Request Logs</field>
        <field name="res_model">ft.ai.insights.log</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
