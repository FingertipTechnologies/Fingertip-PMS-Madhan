<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_evaluation_list" model="ir.ui.view">
        <field name="name">ft.evaluation.list</field>
        <field name="model">ft.evaluation</field>
        <field name="arch" type="xml">
            <!-- Every column carries the same fixed width, so Odoo spreads the
                 leftover space equally instead of letting Assignment absorb it
                 all and strand the right-aligned Rating against the Date. -->
            <list string="Evaluations" class="o_ft_evaluation_list">
                <field name="trainee_id" width="180px"/>
                <field name="assignment_id" width="180px"/>
                <field name="rating" width="180px"/>
                <field name="create_date" string="Date" width="180px"/>
            </list>
        </field>
    </record>

    <record id="view_evaluation_form" model="ir.ui.view">
        <field name="name">ft.evaluation.form</field>
        <field name="model">ft.evaluation</field>
        <field name="arch" type="xml">
            <form string="Evaluation">
                <sheet>
                    <group>
                        <field name="assignment_id"
                               options="{'no_create': True}"/>
                        <field name="trainee_id"
                               options="{'no_create': True}"/>
                        <field name="rating"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_evaluation_search" model="ir.ui.view">
        <field name="name">ft.evaluation.search</field>
        <field name="model">ft.evaluation</field>
        <field name="arch" type="xml">
            <search string="Evaluations">
                <field name="trainee_id"/>
                <field name="assignment_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_trainee" string="Trainee"
                            context="{'group_by': 'trainee_id'}"/>
                    <filter name="group_assignment" string="Assignment"
                            context="{'group_by': 'assignment_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_evaluation" model="ir.actions.act_window">
        <field name="name">Evaluation</field>
        <field name="res_model">ft.evaluation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_evaluation_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Record an evaluation</p>
            <p>Pick an assignment and trainee, then give a rating (0 - 100).</p>
        </field>
    </record>

</odoo>
